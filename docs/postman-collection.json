    {
      "name": "Reservations",
      "item": [
        {
          "name": "Get Available Tables",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reservations/available-tables?restaurantId={{restaurantId}}&reservadoPara=2025-12-01T19:00:00.000Z&duracion=90",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations",
                "available-tables"
              ],
              "query": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}"
                },
                {
                  "key": "reservadoPara",
                  "value": "2025-12-01T19:00:00.000Z"
                },
                {
                  "key": "duracion",
                  "value": "90"
                }
              ]
            }
          }
        },
        {
          "name": "Create Reservation (Client Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data) {",
                  "    pm.collectionVariables.set('reservationId', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idRestaurante\": \"{{restaurantId}}\",\n  \"mesaId\": \"<uuid-de-la-mesa>\",\n  \"tamannoReserva\": 4,\n  \"reservadoPara\": \"2025-12-01T19:00:00.000Z\",\n  \"duracionReserva\": 90,\n  \"notas\": \"Mesa cerca de la ventana por favor\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/reservations"
          }
        },
        {
          "name": "Get Reservation by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/reservations/{{reservationId}}"
          }
        },
        {
          "name": "Get My Reservations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/reservations/me"
