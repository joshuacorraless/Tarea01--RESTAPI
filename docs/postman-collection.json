              "raw": "{\n  \"name\": \"La Casona\",\n  \"description\": \"Restaurante de comida tipica costarricense\",\n  \"address\": \"San Jose, Costa Rica\",\n  \"phone\": \"+506 2222-2222\",\n  \"openingHours\": \"Lun-Vie 8:00-22:00\"\n}",
