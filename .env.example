PORT=3000

# postgresql
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=restaurant_db

# keycloak admin console
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# keycloak api config (usada por docker compose para sustituir ${VAR} en compose.yaml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/restaurant_db
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=restaurant-realm
KEYCLOAK_CLIENT_ID=restaurant-api
KEYCLOAK_CLIENT_SECRET=<obtener-de-keycloak-admin-console>
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=<obtener-de-keycloak-admin-console>
