# puerto del servidor
PORT=3000

# =============================================
# postgresql
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=restaurant_db

# conexion directa (para desarrollo local sin docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/restaurant_db

# =============================================
# keycloak - admin console
# =============================================
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# =============================================
# keycloak - configuracion de la api
# =============================================
# - con docker compose: http://keycloak:8080
# - sin docker (local):  http://localhost:8080
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=restaurant-realm

# client para login (ropc grant)
# este secret lo obtenes de keycloak admin console despues de crear el client
KEYCLOAK_CLIENT_ID=restaurant-api
KEYCLOAK_CLIENT_SECRET=your-client-secret

# client para admin api (crear usuarios, asignar roles)
# este secret lo obtenes de keycloak admin console > clients > admin-cli > credentials
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-secret
